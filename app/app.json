{
  "expo": {
    "name": "DramaFlix",
    "slug": "dramaflix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C1B1F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dramaflix.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1C1B1F",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.dramaflix.app",
      "versionCode": 1,
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-screen-orientation",
      "expo-secure-store",
      "./plugins/withNetworkSecurityConfig"
    ],
    "scheme": "dramaflix",
    "extra": {
      "apiBaseUrl": "http://43.159.62.11",
      "eas": {
        "projectId": "fb1a163c-5a7e-4550-8bc6-04cd63290a85"
      }
    },
    "owner": "lbx1123"
  }
}
