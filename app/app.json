{
  "expo": {
    "name": "DramaFlix",
    "slug": "dramaflix",
    "version": "1.4.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C1B1F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dramaflix.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationsUsageDescription": "需要推送通知权限以接收新剧更新和观看提醒",
        "NSCameraUsageDescription": "需要相机权限以拍摄头像或上传内容",
        "NSPhotoLibraryUsageDescription": "需要照片库权限以选择和上传图片",
        "NSMicrophoneUsageDescription": "需要麦克风权限以录制语音或视频",
        "NSLocationWhenInUseUsageDescription": "需要位置权限以提供本地化内容推荐",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "需要后台位置权限以持续提供本地化推荐"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1C1B1F",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.dramaflix.app",
      "versionCode": 18,
      "usesCleartextTraffic": true,
      "permissions": [
        "POST_NOTIFICATIONS",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-screen-orientation",
      "expo-secure-store",
      "./plugins/withNetworkSecurityConfig"
    ],
    "scheme": "dramaflix",
    "extra": {
      "apiBaseUrl": "http://43.159.62.11",
      "eas": {
        "projectId": "4b929053-03ae-4a05-80dc-02021189eb9c"
      }
    }
  }
}
